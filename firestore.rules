rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function profilePath() {
      return /databases/$(database)/documents/profiles/$(request.auth.uid);
    }

    function hasProfile() {
      return isSignedIn() && exists(profilePath());
    }

    function profile() {
      return get(profilePath());
    }

    function isAdmin() {
      return hasProfile() && profile().data.role == 'admin';
    }

    function isManager() {
      return hasProfile() && profile().data.role == 'manager';
    }

    function isViewer() {
      return hasProfile() && profile().data.role == 'viewer';
    }

    function canReadAppData() {
      return isAdmin() || isManager() || isViewer();
    }

    function canManageProducts() {
      return isAdmin() || isManager();
    }

    function isValidProductStatus() {
      return request.resource.data.status == 'active'
        || request.resource.data.status == 'inactive';
    }

    function isValidProductCreate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'sku',
          'description',
          'status',
          'stock',
          'lowStockThreshold',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.keys().hasAll([
          'name',
          'sku',
          'description',
          'status',
          'stock',
          'lowStockThreshold',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.sku is string
        && request.resource.data.sku.size() > 0
        && request.resource.data.sku.size() <= 64
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.lowStockThreshold is int
        && request.resource.data.lowStockThreshold >= 0
        && isValidProductStatus()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function isValidProductUpdate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'sku',
          'description',
          'status',
          'stock',
          'lowStockThreshold',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.keys().hasAll([
          'name',
          'sku',
          'description',
          'status',
          'stock',
          'lowStockThreshold',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.sku is string
        && request.resource.data.sku.size() > 0
        && request.resource.data.sku.size() <= 64
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.lowStockThreshold is int
        && request.resource.data.lowStockThreshold >= 0
        && isValidProductStatus()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.updatedBy == request.auth.uid;
    }

    match /profiles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Intentionally locked down for MVP.
      // Role assignment and profile management should happen
      // through trusted admin flows / server-side tools later.
      allow create, update, delete: if false;
    }

    match /products/{productId} {
      allow read: if canReadAppData();
      allow create: if canManageProducts() && isValidProductCreate();
      allow update: if canManageProducts() && isValidProductUpdate();
      allow delete: if canManageProducts();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
